{
  "id": "fugu",
  "displayName": "Fugu (Conductor)",
  "description": "OpenFugu's Conductor variant as a setup: a coordinator plans a sequential workflow with selective visibility (the access_list) over the pool, then replays it step by step. No weights — pure prompting, which the Conductor paper shows captures most of the value.",
  "version": "0.1.0",

  "roomDefaults": { "maxSummonsPerRoom": 8 },

  "monad": {
    "policy": "conductor-dag",
    "maxTurns": 6,
    "coordinatorAgentId": "gaia",
    "roles": ["thinker", "worker", "verifier"],
    "slots": [
      { "index": 0, "agentId": "gaia",  "label": "thinker",  "defaultRole": "thinker" },
      { "index": 1, "agentId": "terry", "label": "worker",   "defaultRole": "worker" },
      { "index": 2, "agentId": "sidia", "label": "verifier", "defaultRole": "verifier" }
    ],
    "terminate": { "on": "verifier-accept", "acceptToken": "ACCEPT" },
    "policyConfig": { "defaultRole": "worker" }
  },

  "agents": [
    { "ref": "gaia",  "role": "thinker" },
    { "ref": "terry", "role": "worker" },
    { "ref": "sidia", "role": "verifier" }
  ],

  "roles": {
    "gaia":  "./roles/thinker.md",
    "terry": "./roles/worker.md",
    "sidia": "./roles/verifier.md"
  }
}
