{
  "name": "gaia-pi-wrapper",
  "version": "0.1.0",
  "description": "GAIA local-first multi-agent workspace built on the Pi SDK.",
  "type": "module",
  "bin": {
    "gaia": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "web:dev": "vite --host 127.0.0.1 web",
    "web:build": "vite build web"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.70.6",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@mariozechner/pi-tui": "^0.70.6",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "license": "MIT"
}
