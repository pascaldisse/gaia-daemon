{
  "name": "gaia-daemon",
  "version": "2.0.0",
  "description": "GAIA \u2014 local-first multi-agent workspace. Rooms, personas, three harnesses (pi/claude/codex), sandboxed summons, monad routing, voice.",
  "type": "module",
  "bin": {
    "gaia": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun scripts/build-daemon.mjs",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json",
    "test": "bun test test/",
    "start": "bun src/cli.ts",
    "stop": "pids=$(lsof -ti tcp:8787); if [ -n \"$pids\" ]; then kill $pids && echo \"stopped gaia (pid $pids) on :8787\"; else echo \"gaia not running on :8787\"; fi",
    "restart": "bun run stop; bun run start",
    "tauri:dev": "bun scripts/gaia-engine.mjs dev",
    "tauri:build": "bun scripts/gaia-engine.mjs build",
    "tauri:bundle:scratch": "bun scripts/gaia-engine.mjs bundle",
    "mobile:ios:init": "bunx tauri ios init --ci",
    "mobile:ios:dev": "bun scripts/gaia-mobile.mjs ios-dev",
    "mobile:ios:open": "bun scripts/gaia-mobile.mjs ios-open",
    "mobile:url": "bun scripts/gaia-mobile.mjs url",
    "tauri": "tauri",
    "mobile:ios:sim": "bun scripts/gaia-mobile.mjs ios-dev --simulator --device \"iPhone 17 Pro\"",
    "mobile:ios:device": "bun scripts/gaia-mobile.mjs device"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "gpt-tokenizer": "^3.4.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
