{
  "name": "gaia-daemon",
  "version": "2.0.0",
  "description": "GAIA \u2014 local-first multi-agent workspace. Rooms, personas, three harnesses (pi/claude/codex), sandboxed summons, monad routing, voice.",
  "type": "module",
  "bin": {
    "gaia": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "start": "tsx src/cli.ts",
    "stop": "pids=$(lsof -ti tcp:8787); if [ -n \"$pids\" ]; then kill $pids && echo \"stopped gaia (pid $pids) on :8787\"; else echo \"gaia not running on :8787\"; fi",
    "restart": "npm run stop; npm start",
    "dev": "tsx src/cli.ts --dev",
    "dev:watch": "tsx watch src/cli.ts --dev",
    "tauri:dev": "node scripts/gaia-engine.mjs dev",
    "tauri:dev:cef": "GAIA_ENGINE=cef node scripts/gaia-engine.mjs dev",
    "tauri:build": "node scripts/gaia-engine.mjs build",
    "tauri:build:cef": "GAIA_ENGINE=cef node scripts/gaia-engine.mjs build",
    "tauri:bundle:scratch": "node scripts/gaia-engine.mjs bundle",
    "tauri:bundle:scratch:cef": "GAIA_ENGINE=cef node scripts/gaia-engine.mjs bundle",
    "mobile:ios:init": "npm exec tauri -- ios init --ci",
    "mobile:ios:dev": "node scripts/gaia-mobile.mjs ios-dev",
    "mobile:ios:open": "node scripts/gaia-mobile.mjs ios-open",
    "mobile:url": "node scripts/gaia-mobile.mjs url",
    "tauri": "tauri",
    "mobile:ios:sim": "node scripts/gaia-mobile.mjs ios-dev --simulator --device \"iPhone 17 Pro\"",
    "mobile:ios:device": "node scripts/gaia-mobile.mjs device"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "license": "MIT"
}
