{
  "name": "gaia-daemon",
  "version": "2.0.0",
  "description": "GAIA — local-first multi-agent workspace. Rooms, personas, three harnesses (pi/claude/codex), sandboxed summons, monad routing, voice.",
  "type": "module",
  "bin": {
    "gaia": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "start": "node dist/cli.js",
    "stop": "pids=$(lsof -ti tcp:8787); if [ -n \"$pids\" ]; then kill $pids && echo \"stopped gaia (pid $pids) on :8787\"; else echo \"gaia not running on :8787\"; fi",
    "restart": "npm run stop; npm start",
    "dev": "tsx src/cli.ts --dev",
    "dev:watch": "tsx watch src/cli.ts --dev"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "license": "MIT"
}
